{
  "name": "myshepherdline-worker",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev --config ./wrangler.toml",
    "deploy": "wrangler deploy --config ./wrangler.toml",
    "test": "vitest run",
    "test:win": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.16.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8"
  }
}
