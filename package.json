{
  "name": "myshepherdline",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@supabase/supabase-js": "^2.106.2",
    "expo": "~56.0.5",
    "expo-constants": "~56.0.16",
    "expo-device": "^56.0.4",
    "expo-font": "~56.0.5",
    "expo-image": "^56.0.9",
    "expo-linear-gradient": "^56.0.4",
    "expo-linking": "~56.0.12",
    "expo-notifications": "^56.0.14",
    "expo-router": "~56.2.7",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.29.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:win": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "test:worker": "npm run typecheck --workspace myshepherdline-worker && npm run test --workspace myshepherdline-worker",
    "test:e2e": "maestro test .maestro/flows",
    "test:e2e:smoke": "maestro test .maestro/flows/01-landing-to-sign-in.yaml .maestro/flows/02-auth-sign-in-success.yaml .maestro/flows/10-sign-out.yaml",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run test:worker",
    "verify:win": "npm run typecheck && npm run lint && npm run test:win && npm run test:worker",
    "check:env": "node scripts/check-env.mjs",
    "setup:worker": "powershell -ExecutionPolicy Bypass -File scripts/setup-worker.ps1",
    "setup:supabase": "node scripts/open-supabase-sql.mjs"
  },
  "private": true,
  "workspaces": [
    "worker"
  ]
}
