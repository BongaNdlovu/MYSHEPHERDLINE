EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
EXPO_PUBLIC_WORKER_API_URL=https://your-worker.workers.dev

# Set only after counsel completes docs/compliance/legal-review-signoff.md
# EXPO_PUBLIC_LEGAL_REVIEW_COMPLETE=true

# Sentry crash reporting (https://sentry.io — org lift-prayer-network / project android-wx)
# EXPO_PUBLIC_SENTRY_DSN=https://yourPublicKey@o0.ingest.us.sentry.io/0
# EXPO_PUBLIC_MONITORING_ENABLED=true
# Local/EAS native builds — never commit; use: eas secret:create --name SENTRY_AUTH_TOKEN
# SENTRY_AUTH_TOKEN=

# Dev / break-glass only — enables local Supabase report fallback when Worker is down.
# EXPO_PUBLIC_ALLOW_REPORT_FALLBACK=true

# E2E / RLS live tests (optional — use real staging accounts and records)
# E2E_EMAIL=
# E2E_PASSWORD=
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# E2E_INACTIVE_EMAIL=
# E2E_INACTIVE_PASSWORD=
# E2E_MEMBER_NAME=
# E2E_TASK_TITLE=
# RLS_OTHER_MEMBER_NAME=
# RLS_ADMIN_TASK_TITLE=
# RLS_ASSIGNED_MEMBER_NAME=

# Operator token for scripts/disable-public-signup.mjs (never commit)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=your-project-ref

# Worker secrets (set via wrangler secret put, not in the mobile app):
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# DIGEST_CRON_SECRET
