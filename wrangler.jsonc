{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myshepherdline",
  "compatibility_date": "2026-05-26",
  "build": {
    "command": "npx expo export --platform web"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
